generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth ───────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role      @default(OWNER)
  theme         String    @default("system")
  avatar        String?   @db.Text
  activeOrgId   String?
  phone          String?   // E.164 with country code, e.g. +5214423399798
  notifyEmail    Boolean   @default(true)
  notifyWhatsapp Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  organizations    Organization[] @relation("OrganizationOwner")
  memberships      Membership[]
  reports          AIReport[]
  chatMessages     AIChatMessage[]
  notifications    Notification[]
  apiKeys          ApiKey[]
  sentInvitations  Invitation[]  @relation("SentInvitations")
  activityLogs     ActivityLog[]
  alertRules       AlertRule[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Organization ───────────────────────────────────────────────────

model Organization {
  id          String   @id @default(cuid())
  name        String
  industry    String?
  logo        String?  @db.Text
  brandColor  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ownerId String
  owner   User   @relation("OrganizationOwner", fields: [ownerId], references: [id])

  @@index([ownerId])

  subscription   Subscription?
  memberships    Membership[]
  integrations   Integration[]
  metrics        Metric[]
  dashboards     Dashboard[]
  reports        AIReport[]
  chatMessages   AIChatMessage[]
  invitations    Invitation[]
  satCredential  SatCredential?
  satDownloadRequests SatDownloadRequest[]
  activityLogs   ActivityLog[]
  alertRules     AlertRule[]
}

model Membership {
  id              String         @id @default(cuid())
  role            MembershipRole @default(VIEWER)
  allowedSections String[]       @default([])

  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
}

// ─── Subscription & Billing ─────────────────────────────────────────

model Subscription {
  id                   String             @id @default(cuid())
  stripeCustomerId     String             @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  status               SubscriptionStatus @default(TRIALING)
  plan                 Plan               @default(STARTER)
  interval             BillingInterval    @default(MONTHLY)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// ─── Integrations ───────────────────────────────────────────────────

model Integration {
  id           String          @id @default(cuid())
  type         IntegrationType
  accessToken  String          @db.Text
  refreshToken String?         @db.Text
  expiresAt    DateTime?
  metadata     Json?
  isActive     Boolean         @default(true)
  lastSyncAt   DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, type])
}

// ─── Metrics ────────────────────────────────────────────────────────

model Metric {
  id        String         @id @default(cuid())
  category  MetricCategory
  name      String
  value     Float
  unit      String?
  period    DateTime
  source    IntegrationType?
  metadata  Json?
  createdAt DateTime       @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, category, period])
}

// ─── Dashboards ─────────────────────────────────────────────────────

model Dashboard {
  id        String   @id @default(cuid())
  name      String
  layout    Json
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// ─── AI Reports ─────────────────────────────────────────────────────

model AIReport {
  id        String       @id @default(cuid())
  title     String
  content   String       @db.Text
  summary   String       @db.Text
  period    DateTime
  type      ReportType   @default(MONTHLY)
  status    ReportStatus @default(GENERATING)
  createdAt DateTime     @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  generatedById  String
  generatedBy    User         @relation(fields: [generatedById], references: [id])
}

model AIChatMessage {
  id        String   @id @default(cuid())
  role      String
  content   String   @db.Text
  createdAt DateTime @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id])

  @@index([organizationId, createdAt])
}

// ─── Invitations ────────────────────────────────────────────────────

model Invitation {
  id              String         @id @default(cuid())
  email           String
  role            MembershipRole @default(VIEWER)
  allowedSections String[]       @default([])
  token           String         @unique @default(cuid())
  expiresAt       DateTime
  acceptedAt      DateTime?
  createdAt       DateTime       @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedById    String
  invitedBy      User         @relation("SentInvitations", fields: [invitedById], references: [id])

  @@unique([organizationId, email])
  @@index([token])
}

// ─── Enums ──────────────────────────────────────────────────────────

enum Role {
  OWNER
  ADMIN
  MEMBER
}

enum MembershipRole {
  ADMIN
  EDITOR
  VIEWER
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
}

enum Plan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum BillingInterval {
  MONTHLY
  ANNUAL
}

enum IntegrationType {
  QUICKBOOKS
  HUBSPOT
  META_ADS
  SAT
  CUSTOM_API
}

enum MetricCategory {
  FINANCE
  SALES
  OPERATIONS
  HR
  MARKETING
}

enum ReportType {
  MONTHLY
  QUARTERLY
  ANNUAL
  CUSTOM
}

enum ReportStatus {
  GENERATING
  COMPLETED
  FAILED
}

// ─── Notifications ──────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String   @default("info")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

// ─── Activity Log (team usage analytics + audit trail) ──────────────

model ActivityLog {
  id             String   @id @default(cuid())
  action         String   // "login" | "page.view" | "metric.create" | "report.generate" | ...
  detail         String?  @db.Text
  path           String?
  createdAt      DateTime @default(now())

  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([userId, createdAt])
}

// ─── Alert Rules ────────────────────────────────────────────────────

model AlertRule {
  id             String   @id @default(cuid())
  metricName     String   // e.g. "Ventas del Mes"
  category       MetricCategory
  condition      String   // "below" | "above" | "change_pct_down" | "change_pct_up"
  threshold      Float    // e.g. 20 (percent) or 500000 (absolute)
  isActive       Boolean  @default(true)
  lastTriggered  DateTime?
  createdAt      DateTime @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdById    String
  createdBy      User         @relation(fields: [createdById], references: [id])

  @@index([organizationId])
}

// ─── API Keys ───────────────────────────────────────────────────────

model ApiKey {
  id        String   @id @default(cuid())
  name      String
  key       String   @unique
  lastUsed  DateTime?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
}

// ─── SAT / Facturapi ────────────────────────────────────────────────

model SatCredential {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  rfc            String
  encryptedCer      String @db.Text
  encryptedKey      String @db.Text
  encryptedPassword String @db.Text
  syncStatus     String       @default("pending") // pending | syncing | synced | error
  lastSyncAt     DateTime?
  lastError      String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model SatDownloadRequest {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  satRequestId   String?  // request id returned by SAT query
  downloadType   String   // "issued" | "received"
  periodFrom     DateTime
  periodTo       DateTime
  status         String   @default("pending") // pending | accepted | finished | downloaded | failed | expired
  packageIds     String[] @default([])
  attempts       Int      @default(0)
  lastError      String?
  lastCheckedAt  DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId, status])
}
